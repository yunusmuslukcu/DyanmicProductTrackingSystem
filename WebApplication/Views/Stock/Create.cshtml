@model Entity.Concrete.Stock

@{
    ViewData["Title"] = "Yeni Stok Tanımlama";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0 mt-4">
                @* Header: Koyu tema ve stok ikonu *@
                <div class="card-header text-white d-flex align-items-center" style="background-color: #212529;">
                    <i class="fas fa-boxes me-2"></i>
                    <h5 class="mb-0 py-2"> Yeni Stok Girişi</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        
                        <div class="row">
                            @* Ürün Seçimi - ProductController'dan gelen ViewBag *@
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-primary">
                                    <i class="fas fa-shopping-cart me-1"></i> Stoklanacak Ürün
                                </label>
                                <select asp-for="ProductId" class="form-select border-2 border-primary shadow-none"
                                        asp-items="@ViewBag.ProductList" required>
                                    <option value="">--- Ürün Seçiniz ---</option>
                                </select>
                            </div>

                            @* Stok Adedi *@
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-layer-group me-1"></i> Başlangıç Stok Adedi
                                </label>
                                <input type="number" asp-for="Quantity" class="form-control border-2 shadow-none"
                                       placeholder="Örn: 100" required min="0" />
                            </div>

                            @* Kritik Stok Seviyesi *@
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-danger">
                                    <i class="fas fa-exclamation-triangle me-1"></i> Kritik Seviye Uyarısı
                                </label>
                                <input type="number" asp-for="CriticalLevel" class="form-control border-2 border-danger shadow-none"
                                       placeholder="Örn: 5" required min="1" />
                                <small class="text-muted italic">Stok bu sayının altına düştüğünde sistem uyarı verecektir.</small>
                            </div>
                        </div>

                        <hr class="my-4" />

                        @* Alt Butonlar - Tam istediğin düzende *@
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill text-decoration-none">
                                <i class="fas fa-arrow-left me-1"></i> Vazgeç
                            </a>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow">
                                <i class="fas fa-check-circle me-1"></i> Stoğu Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>