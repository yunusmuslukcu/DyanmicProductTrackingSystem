@model List<Entity.Concrete.Stock>

@{
    ViewData["Title"] = "Stok Listesi";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm border-0 mt-4">
                @* Header: Arama ve Ekleme Butonları Aynı Çizgide *@
                <div class="card-header bg-dark text-white">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <h5 class="mb-0 py-1"><i class="fas fa-warehouse me-2"></i> Stok Durum Takibi</h5>
                        
                        @* Arama ve Ekleme Grubu *@
                        <div class="d-flex align-items-center gap-2">
                            @* Ürün Adına Göre Arama Formu *@
                            <form asp-action="Index" method="get" class="d-flex align-items-center">
                                <div class="input-group input-group-sm">
                                    <input type="text" name="searchText" value="@ViewBag.SearchText"
                                           class="form-control border-0 shadow-none rounded-start-pill px-3"
                                           placeholder="Ürün adı ile ara..." style="width: 200px;">
                                    <button type="submit" class="btn btn-light btn-sm rounded-end-pill px-3">
                                        <i class="fas fa-search text-dark"></i>
                                    </button>
                                </div>
                                @if (!string.IsNullOrEmpty(ViewBag.SearchText))
                                {
                                    <a asp-action="Index" class="btn btn-sm btn-outline-light border-0 rounded-circle ms-1" title="Aramayı Temizle">
                                        <i class="fas fa-times"></i>
                                    </a>
                                }
                            </form>

                            @* Yeni Stok Girişi *@
                            <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm">
                                <i class="fas fa-plus-circle me-1"></i> Yeni Stok Girişi
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Ürün Bilgisi</th>
                                    <th>Mevcut Adet</th>
                                    <th>Kritik Stok Seviyesi</th>
                                    <th>Durum</th>
                                    <th class="text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                @{
                                                    var productList = ViewBag.Products as List<Entity.Concrete.Product>;
                                                    var product = productList?.FirstOrDefault(x => x.ProductID == item.ProductId);
                                                }
                                                @* Ürün Adı *@
                                                <div class="fw-bold text-dark" style="font-size: 1.05rem;">@product?.ProductName</div>
                                                
                                                @* Dinamik Özellikler *@
                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                    @if (product?.DynamicAttributes != null && product.DynamicAttributes.Any())
                                                    {
                                                        @foreach (var attr in product.DynamicAttributes)
                                                        {
                                                            <span class="badge bg-secondary bg-opacity-10 text-muted border-0 fw-normal" style="font-size: 0.75rem; padding: 0.4em 0.7em;">
                                                                <i class="fas fa-info-circle me-1" style="font-size: 0.7rem;"></i>
                                                                <strong>@attr.Key:</strong> @attr.Value
                                                            </span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <small class="text-muted" style="font-size: 0.7rem;">ID: @item.ProductId</small>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <span class="fw-bold fs-5">@item.Quantity Adet</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary rounded-pill px-3">@item.CriticalLevel</span>
                                            </td>
                                            <td>
                                                @if (item.Quantity <= item.CriticalLevel)
                                                {
                                                    <span class="badge bg-danger rounded-pill px-3 animate__animated animate__flash animate__infinite">
                                                        <i class="fas fa-exclamation-triangle me-1"></i> Kritik Stok!
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success rounded-pill px-3">
                                                        <i class="fas fa-check me-1"></i> Güvenli
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="Update" asp-route-id="@item.StockID"
                                                       class="btn btn-warning btn-sm px-3 me-2 rounded-pill fw-bold shadow-sm" style="color: #212529;">
                                                    <i class="fa fa-edit"></i> Güncelle
                                                </a>

                                                <button type="button" class="btn btn-outline-danger btn-sm px-3 rounded-pill fw-bold shadow-sm"
                                                        onclick="deleteStock('@item.StockID', '@item.ProductId')">
                                                    <i class="fas fa-trash"></i> Sil
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="fas fa-search-minus fa-3x mb-3 d-block opacity-25"></i>
                                            Aradığınız kriterlere uygun stok kaydı bulunamadı.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.3s;
    }

    .btn:active {
        transform: scale(0.95);
    }

    .badge {
        letter-spacing: 0.3px;
    }

    /* Arama kutusu odaklandığında genişleme efekti */
    .input-group .form-control:focus {
        width: 250px !important;
        transition: all 0.3s ease;
        background-color: white !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteStock(id, productName) {
        Swal.fire({
        title: 'Stok Kaydını Sil?',
        text: "Bu stok kaydı kalıcı olarak silinecektir!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Evet, Sil!',
        cancelButtonText: 'Vazgeç'
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = "/Stock/Delete/" + id;
        }
        })
        }
    </script>
}