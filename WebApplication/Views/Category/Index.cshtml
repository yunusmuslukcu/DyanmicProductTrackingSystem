@model List<Entity.Concrete.Category>

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 mt-4">
        @* Header: Arama ve Ekleme Butonları Aynı Çizgide *@
        <div class="card-header text-white" style="background-color: #212529;">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <h5 class="mb-0 py-1"><i class="fa fa-list me-2"></i> Mevcut Kategoriler</h5>
                
                @* Arama ve Ekleme Grubu *@
                <div class="d-flex align-items-center gap-2">
                    @* Arama Formu *@
                    <form asp-action="Index" method="get" class="d-flex align-items-center">
                        <div class="input-group input-group-sm">
                            <input type="text" name="searchText" value="@ViewBag.SearchText"
                                   class="form-control border-0 shadow-none rounded-start-pill px-3"
                                   placeholder="Kategori ara..." style="width: 200px;">
                            <button type="submit" class="btn btn-light btn-sm rounded-end-pill px-3">
                                <i class="fas fa-search text-dark"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(ViewBag.SearchText))
                        {
                            <a asp-action="Index" class="btn btn-sm btn-outline-light border-0 rounded-circle ms-1" title="Aramayı Temizle">
                                <i class="fas fa-times"></i>
                            </a>
                        }
                    </form>

                    @* Yeni Kategori Ekle *@
                    <a href="/Category/Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm">
                        <i class="fa fa-plus-circle me-1"></i> Yeni Kategori Ekle
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 30%">Kategori Adı</th>
                            <th style="width: 45%">Özellik Şablonu</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark" style="font-size: 1.05rem;">
                                        <i class="@(string.IsNullOrEmpty(item.CategoryIcon) ? "fa fa-tag" : item.CategoryIcon) text-primary me-2" style="width: 25px;"></i>
                                        @item.CategoryName
                                    </td>
                                    <td>
                                        @if (item.AttributeTemplate != null && item.AttributeTemplate.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var attr in item.AttributeTemplate)
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-muted border-0 fw-normal" style="font-size: 0.75rem; padding: 0.4em 0.7em;">
                                                        <i class="fas fa-info-circle me-1" style="font-size: 0.7rem;"></i>
                                                        @attr
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic text-opacity-50">Şablon tanımlanmadı</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Update" asp-route-id="@item.CategoryID"
                                               class="btn btn-warning btn-sm px-3 me-2 rounded-pill fw-bold shadow-sm" style="color: #212529;">
                                            <i class="fa fa-edit me-1"></i> Güncelle
                                        </a>

                                        <button type="button" class="btn btn-outline-danger btn-sm px-3 rounded-pill fw-bold shadow-sm"
                                                onclick="deleteCategory('@item.CategoryID', '@item.CategoryName')">
                                            <i class="fas fa-trash me-1"></i> Sil
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="fas fa-search-minus fa-3x mb-3 d-block opacity-25"></i>
                                    Aradığınız kriterlere uygun kategori bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.3s;
    }

    .btn:active {
        transform: scale(0.95);
    }

    .badge {
        letter-spacing: 0.3px;
    }
    
    /* Arama kutusu için özel dokunuş */
    .input-group .form-control:focus {
        width: 250px !important;
        transition: all 0.3s ease;
        background-color: white !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteCategory(id, name) {
        Swal.fire({
        title: 'Emin misiniz?',
        text: name + " kategorisini silmek üzeresiniz. Bu işlem geri alınamaz!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil!',
        confirmButtonColor: '#d33',
        cancelButtonText: 'Vazgeç',
        cancelButtonColor: '#3085d6',
        reverseButtons: false
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = "/Category/Delete/" + id;
        }
        })
        }
    </script>
}