@model WebApplication.Models.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { 
            background-color: #f4f7f6; 
            color: #333; 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            font-family: 'Inter', sans-serif;
            margin: 0;
        }
        .login-card { 
            background: #ffffff; 
            border: none;
            border-radius: 12px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
        }
        .form-control { 
            background: #f9f9f9; 
            border: 1px solid #ddd; 
            border-radius: 6px; 
            padding: 10px 12px;
            font-size: 0.95rem;
        }
        .form-control:focus { 
            background: #fff; 
            border-color: #198754; 
            box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.15); 
        }
        .btn-login { 
            background: #198754; 
            border: none; 
            border-radius: 6px; 
            padding: 12px; 
            font-weight: 600; 
            transition: all 0.3s;
        }
        .btn-login:hover { 
            background: #157347; 
            transform: translateY(-1px); 
        }
        .form-label { 
            color: #555; 
            font-weight: 600; 
            margin-bottom: 5px;
        }
        .form-check-input:checked {
            background-color: #198754;
            border-color: #198754;
        }
        .login-footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        .input-group-text {
            border: 1px solid #ddd;
            border-radius: 6px 0 0 6px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card login-card shadow">
                <div class="card-body p-4 p-lg-5">
                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-dark mb-1">Yönetim Paneli</h4>
                        <p class="text-muted small">Devam etmek için giriş yapın!</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label class="form-label small">Kullanıcı Adı</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                                <input asp-for="Username" class="form-control border-start-0" placeholder="Kullanıcı adınız" />
                            </div>
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Şifre</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                                <label class="form-check-label small text-muted" for="RememberMe">
                                    Beni Hatırlat
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-login w-100 text-white shadow-sm">
                            Giriş Yap
                        </button>

                        <div class="login-footer">
                            <span class="text-muted small">Hesabınız yok mu?</span>
                            <a href="/Account/Register" class="text-success text-decoration-none fw-bold small ms-1">Hemen Kayıt Ol</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>