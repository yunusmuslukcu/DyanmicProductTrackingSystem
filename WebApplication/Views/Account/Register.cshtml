@model WebApplication.Models.RegisterViewModel

@{
    ViewData["Title"] = "Yeni Kayıt";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        body { 
            background-color: #f4f7f6; /* Ferah açık gri arka plan */
            color: #333; 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            font-family: 'Inter', sans-serif;
            margin: 0;
        }
        .register-card { 
            background: #ffffff; 
            border: none;
            border-radius: 12px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
        }
        .form-control { 
            background: #f9f9f9; 
            border: 1px solid #ddd; 
            color: #333 !important; 
            border-radius: 6px; 
            padding: 8px 12px;
            font-size: 0.9rem;
        }
        .form-control:focus { 
            background: #fff; 
            border-color: #198754; 
            box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.15); 
        }
        .btn-register { 
            background: #198754; 
            border: none; 
            border-radius: 6px; 
            padding: 10px; 
            font-weight: 600; 
            font-size: 0.95rem;
            transition: all 0.3s;
        }
        .btn-register:hover { 
            background: #157347; 
            transform: translateY(-1px); 
        }
        .form-label { 
            color: #555; 
            font-weight: 600; 
            margin-bottom: 4px;
        }
        .text-danger { font-size: 0.75rem; font-weight: 500; }
        
        .mb-3 { margin-bottom: 0.75rem !important; }
        .card-body-custom { padding: 1.5rem 2rem; }

        .login-footer {
            text-align: center;
            margin-top: 15px;
            padding-top: 10px;
            border-top: 1px solid #eee;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card register-card shadow">
                <div class="card-body card-body-custom">
                    <div class="text-center mb-3">
                        <i class="fas fa-user-circle fa-3x text-success mb-2"></i>
                        <h4 class="fw-bold text-dark mb-1">Yeni Hesap</h4>
                        <p class="text-muted small">Panel erişimi için formu doldurun</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small">Ad</label>
                                <input asp-for="Name" class="form-control" placeholder="Ad" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small">Soyad</label>
                                <input asp-for="Surname" class="form-control" placeholder="Soyad" />
                                <span asp-validation-for="Surname" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Kullanıcı Adı</label>
                            <input asp-for="Username" class="form-control" placeholder="kullaniciadi" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">E-posta</label>
                            <input asp-for="Email" class="form-control" placeholder="mail@adres.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Şifre</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Şifre Tekrar</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-register w-100 text-white shadow-sm mt-2">
                            Kayıt Ol
                        </button>

                        <div class="login-footer">
                            <span class="text-muted small">Zaten üye misiniz?</span>
                            <a href="/Account/Login" class="text-success text-decoration-none fw-bold small ms-1">Giriş Yap</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>