@model Entity.Concrete.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-dark text-white d-flex align-items-center">
                    <i class="fas fa-plus-circle me-2"></i>
                    <h5 class="mb-0 py-2"> Yeni Ürün Ekle</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" asp-controller="Product" method="post" id="productForm">
                        
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold"><i class="fas fa-tag me-1"></i> Ürün Adı</label>
                                <input asp-for="ProductName" class="form-control border-2 shadow-none" placeholder="Ürün adını giriniz..." required />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold"><i class="fas fa-copyright me-1"></i> Marka</label>
                                <input asp-for="Brand" class="form-control border-2 shadow-none" placeholder="Marka giriniz..." required />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold"><i class="fas fa-lira-sign me-1"></i> Fiyat (₺)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control border-2 shadow-none" placeholder="0,00" required />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-primary"><i class="fas fa-list me-1"></i> Kategori Seçiniz</label>
                                <select asp-for="CategoryID" id="categoryDropdown" class="form-select border-2 border-primary shadow-none"
                                        asp-items="@ViewBag.CategoryList">
                                    <option value="">--- Kategori Seçiniz ---</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div id="dynamicAttributesArea" class="row p-3 rounded-3 bg-light mx-1">
                            <div class="col-12 text-center py-3 text-muted italic">
                                <i class="fas fa-info-circle me-1"></i> Kategori seçtiğinizde özellikler burada belirecektir.
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Product/Index" class="btn btn-outline-secondary px-4 rounded-pill text-decoration-none">
                                <i class="fas fa-arrow-left me-1"></i> İptal
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">
                                <i class="fas fa-save me-1"></i> Ürünü Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
        $('#categoryDropdown').change(function () {
        var categoryId = $(this).val();
        var attributeArea = $('#dynamicAttributesArea');

        if (!categoryId) {
        attributeArea.html('<div class="col-12 text-center py-3 text-muted italic"><i class="fas fa-info-circle me-1"></i> Kategori seçtiğinizde özellikler burada belirecektir.</div>');
        return;
        }

        $.ajax({
        url: '/Category/GetCategoryAttributes/' + categoryId,
        type: 'GET',
        success: function (attributes) {
        attributeArea.empty();

        if (attributes && attributes.length > 0) {
        attributes.forEach(function (attrName) {
        var inputHtml = `
        <div class="col-md-6 mb-3 animate__animated animate__fadeIn">
        <label class="form-label fw-bold mb-2 text-secondary small">${attrName}</label>
        <input type="text"
        name="DynamicAttributes[${attrName}]"
        class="form-control border-2 shadow-none"
        placeholder="${attrName} değerini giriniz..."
        required />
        </div>`;
        attributeArea.append(inputHtml);
        });
        } else {
        attributeArea.html('<div class="col-12 text-center py-3 text-warning italic">Bu kategoriye ait bir özellik şablonu bulunamadı.</div>');
        }
        },
        error: function () {
        console.error("Özellikler yüklenirken hata oluştu!");
        }
        });
        });
        });
    </script>
}