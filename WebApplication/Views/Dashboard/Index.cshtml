@{
    ViewData["Title"] = "Yönetim Paneli";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="fas fa-chart-line me-2"></i> Genel Bakış</h2>
        <span class="badge bg-primary px-3 py-2 rounded-pill">
            <i class="far fa-calendar-alt me-1"></i> @DateTime.Now.ToString("dd MMMM yyyy")
        </span>
    </div>

    @* --- 1. ADIM: İSTATİSTİK KARTLARI --- *@
    <div class="row g-4 mb-5">
        
        @* 1. KART: TOPLAM CİRO *@
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-body p-4 border-start border-success border-5">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 fw-bold">Toplam Ciro</p>
                            <h3 class="mb-0 text-dark fw-bolder">@ViewBag.TotalSales</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                            <i class="fas fa-lira-sign fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <i class="fas fa-arrow-up text-success me-1"></i> <span class="fw-bold">Canlı Veri</span>
                    </div>
                </div>
            </div>
        </div>

        @* 2. KART: SİPARİŞ ADEDİ *@
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-body p-4 border-start border-primary border-5">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 fw-bold">Sipariş Sayısı</p>
                            <h3 class="mb-0 text-dark fw-bolder">@ViewBag.OrderCount Adet</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                            <i class="fas fa-shopping-basket fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <i class="fas fa-history me-1"></i> Tüm zamanlar
                    </div>
                </div>
            </div>
        </div>

        @* 3. KART: KRİTİK STOKLAR *@
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-body p-4 border-start border-danger border-5 @(ViewBag.CriticalStockCount > 0 ? "animate__animated animate__pulse animate__infinite" : "")">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 fw-bold">Kritik Stok</p>
                            <h3 class="mb-0 text-danger fw-bolder">@ViewBag.CriticalStockCount Ürün</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger">
                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <span class="@(ViewBag.CriticalStockCount > 0 ? "text-danger fw-bold" : "")">
                            @(ViewBag.CriticalStockCount > 0 ? "Acil Müdahale Gerekli!" : "Tüm stoklar güvenli")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* 4. KART: TOPLAM KATEGORİ *@
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-body p-4 border-start border-warning border-5">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted mb-1 fw-bold">Kategoriler</p>
                            <h3 class="mb-0 text-dark fw-bolder">@ViewBag.CategoryCount Kategori</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                            <i class="fas fa-tags fa-2x"></i>
                        </div>
                    </div>
                    <div class="mt-3 small text-muted">
                        <i class="fas fa-list me-1"></i> Kategori çeşitliliği
                    </div>
                </div>
            </div>
        </div>

    </div>
    <div class="row g-4">
        @* --- SON 5 SİPARİŞ TABLOSU --- *@
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-shopping-cart me-2 text-primary"></i> Son 5 Sipariş</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Müşteri</th>
                                    <th>Ürün</th>
                                    <th>Adet</th>
                                    <th>Tutar</th>
                                    <th class="text-end pe-4">Tarih</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in (List<Entity.Concrete.Order>)ViewBag.LastOrders)
                                {
                                    var product = ((List<Entity.Concrete.Product>)ViewBag.AllProducts)
                                                   .FirstOrDefault(x => x.ProductID == item.ProductId);
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.CustomerName</td>
                                        <td>
                                            <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2">
                                                @(product != null ? product.ProductName : "Bilinmeyen Ürün")
                                            </span>
                                        </td>
                                        <td>@item.Quantity</td>
                                        <td class="text-success fw-bold">@item.TotalPrice.ToString("C2")</td>
                                        <td class="text-end pe-4 text-muted small">@item.OrderDate.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* --- KATEGORİ DAĞILIMI (GRAFİK) --- *@
        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-pie-chart me-2 text-warning"></i> Stok Dağılımı</h5>
                </div>
                <div class="card-body">
                    <canvas id="categoryChart" style="min-height: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Controller'dan gelen istatistik verilerini JS dizilerine çeviriyoruz
        const ctx = document.getElementById('categoryChart').getContext('2d');
        
        // C# tarafındaki ViewBag.CategoryStats verisini JS'e paslıyoruz
        const labels = [];
        const data = [];

        @foreach (var stat in ViewBag.CategoryStats)
        {
            @:labels.push("@stat.CategoryName");
            @:data.push(@stat.ProductCount);
        }

        // 2. Grafik Oluşturma
        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: data,
        backgroundColor: [
        '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796'
        ],
        hoverOffset: 15,
        borderWidth: 0
        }]
        },
        options: {
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'bottom',
        labels: { padding: 20, usePointStyle: true }
        }
        },
        cutout: '70%' // Ortayı boşaltıp şık bir halka yapıyoruz
        }
        });
    </script>
}